# ============================================================
# Cypress Visual Journey Intelligence - Environment Template
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# AI Provider (openai)
AI_PROVIDER=openai

# OpenAI API Key — get from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# OpenAI Model
AI_MODEL=gpt-4o

# Maximum tokens per AI response
AI_MAX_TOKENS=4096

# AI creativity/temperature (0.0 = deterministic, 1.0 = creative)
AI_TEMPERATURE=0.7

# Base URL of the e-commerce site under test
BASE_URL=https://www.saucedemo.com

# OpenAI Model (legacy alias)
OPENAI_MODEL=gpt-4o

# AI Analysis toggle (true/false)
ENABLE_AI_ANALYSIS=true

# Screenshot Directory
SCREENSHOT_DIR=cypress/screenshots

# Reports Directory
REPORTS_DIR=reports
